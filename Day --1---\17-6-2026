  // leetcode 53   using        --Kadane's Algorithm



class Solution {
public:
    int maxSubArray(vector<int>& nums) {
       int n=nums.size();
       int maxsum=INT_MIN;
       int sum = 0;
       for(int i=0;i<n;i++){
        sum=sum+nums[i];
        if (sum>maxsum)maxsum=sum;
        if(sum<0)sum=0;
       

        
       }
       return maxsum;
    }
};


