//problem 2-- maxsum subarray    leetcode no. -- 53  using brute force

class Solution {
public:
    int maxSubArray(vector<int>& nums) {
       int n=nums.size();
       int maxsum=INT_MIN;
       for(int i=0;i<n;i++){
        int sum = 0;
        for(int j=i;j<n;j++){
            sum=sum+nums[j];
            maxsum = max(maxsum,sum);

        }
       }
       return maxsum;
    }
};


