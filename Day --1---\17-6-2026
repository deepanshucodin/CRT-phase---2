//problem 3-----sort colors----------leetcode problem no. --75 -using swap


class Solution {
public:
    void sortColors(vector<int>& nums) {
        int n = nums.size();
        for(int i=0;i<n;i++){
            for(int j=0;j<n;j++){
                if(nums[i]<nums[j]){
                    swap(nums[i],nums[j]);
                }

            }
        }
    }
};




